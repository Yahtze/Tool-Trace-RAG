# Copy this file to `.env` and fill in real values.
# `tool_trace_rag/config.py` loads `.env` at runtime and prefers those values
# over the parent shell environment for reproducible local runs.

# --- LLM provider settings ---
# Base URL for OpenAI-compatible chat completions API.
AGENT_BASE_URL=https://api.openai.com/v1
# API key for your provider.
AGENT_API_KEY=your_api_key_here
# Model name used for completions.
AGENT_MODEL=gpt-4o-mini
# HTTP timeout (seconds) for provider requests.
AGENT_TIMEOUT_SECONDS=60

# --- Agent behavior ---
# Max number of tool calls allowed before aborting a run.
AGENT_MAX_TOOL_CALLS=8

# --- Data + evaluation paths ---
# Path to mock customer support dataset used by tools/scripts.
CUSTOMER_SUPPORT_DATA_PATH=data/mock_customer_support.json
# Path to evaluation tasks dataset used by scripts/run_eval.py.
EVAL_TASKS_PATH=data/eval_tasks_milestone_02.json

# --- Trace + vector persistence ---
# Directory where JSON traces are written.
TRACE_DIR=runs/traces
# Directory where Chroma vector DB files are stored.
VECTOR_DIR=runs/vector_store
# Chroma collection name for indexed traces.
VECTOR_COLLECTION_NAME=tool_trace_memory
# Default number of nearest traces returned by standalone query commands.
QUERY_TOP_K=5

# --- Retrieval injection / memory ---
# Opt-in flag for retrieval-augmented task/eval runs.
USE_MEMORY=false
# Number of retrieved traces injected into the agent prompt.
MEMORY_TOP_K=3
# Retrieval filtering policy: successful_only, failed_only, or all.
MEMORY_FILTER=successful_only
# Maximum characters per injected memory snippet.
MEMORY_SNIPPET_MAX_CHARS=1200
# If true, retrieval errors fail the run; if false, fall back to no-memory behavior.
MEMORY_STRICT=false

# --- Embeddings ---
# SentenceTransformer model used for indexing/query embeddings.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
